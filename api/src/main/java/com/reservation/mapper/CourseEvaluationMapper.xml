<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="src.main.java.com.reservation.mapper.CourseEvaluationMapper">

    <!-- 通用结果集映射 -->
    <resultMap id="evaluationResultMap" type="com.reservation.entity.CourseEvaluation">
        <result column="evaluation_id" property="evaluationId"/>
        <result column="booking_id" property="bookingId"/>
        <result column="student_id" property="studentId"/>
        <result column="teacher_id" property="teacherId"/>
        <result column="course_id" property="courseId"/>
        <result column="score" property="score"/>
        <result column="comment" property="comment"/>
        <result column="create_time" property="createTime"/>
    </resultMap>

    <!-- 新补充：插入课程评价 -->
    <insert id="insertEvaluation" parameterType="com.reservation.entity.CourseEvaluation">
        INSERT INTO course_evaluation (
            evaluation_id, booking_id, student_id, teacher_id,
            course_id, score, comment, create_time
        ) VALUES (
            #{evaluationId}, #{bookingId}, #{studentId}, #{teacherId},
            #{courseId}, #{score}, #{comment}, CURRENT_TIMESTAMP()
        )
    </insert>

    <!-- 新补充：根据订单ID查询评价 --><!-- 新补充：根据教师ID查询评价列表 -->
<!-- 新补充：根据课程ID查询评价列表 -->
    </mapper>
