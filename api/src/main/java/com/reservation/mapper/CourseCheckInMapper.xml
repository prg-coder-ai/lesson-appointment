<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="src.main.java.com.reservation.mapper.CourseCheckInMapper">

    <!-- 通用结果集映射 -->
    <resultMap id="checkInResultMap" type="com.reservation.entity.CourseCheckIn">
        <result column="check_in_id" property="checkInId"/>
        <result column="booking_id" property="bookingId"/>
        <result column="student_id" property="studentId"/>
        <result column="teacher_id" property="teacherId"/>
        <result column="course_id" property="courseId"/>
        <result column="check_in_time" property="checkInTime"/>
    </resultMap>

    <!-- 插入课程签到记录 -->
    <insert id="insertCheckIn" parameterType="com.reservation.entity.CourseCheckIn">
        INSERT INTO course_check_in (
            check_in_id, booking_id, student_id, teacher_id,
            course_id, check_in_time
        ) VALUES (
            #{checkInId}, #{bookingId}, #{studentId}, #{teacherId},
            #{courseId}, CURRENT_TIMESTAMP()
        )
    </insert>

    <!-- 根据订单ID查询签到记录 -->
    <select id="getCheckInsByBookingId" parameterType="int" resultMap="checkInResultMap">
        SELECT * FROM course_check_in WHERE booking_id = #{bookingId}
    </select>
</mapper>