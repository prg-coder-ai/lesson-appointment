<?xml version="1.0" encoding="UTF-8"?>
<project name="module_tempcollection" default="compile.module.tempcollection">
  <dirname property="module.tempcollection.basedir" file="${ant.file.module_tempcollection}"/>
  
  <property name="module.jdk.home.tempcollection" value="${project.jdk.home}"/>
  <property name="module.jdk.bin.tempcollection" value="${project.jdk.bin}"/>
  <property name="module.jdk.classpath.tempcollection" value="${project.jdk.classpath}"/>
  
  <property name="compiler.args.tempcollection" value="-encoding UTF-8 -source 8 -target 8 ${compiler.args}"/>
  
  <property name="tempcollection.output.dir" value="${module.tempcollection.basedir}/classes/production/TempCollection"/>
  <property name="tempcollection.testoutput.dir" value="${module.tempcollection.basedir}/classes/test/TempCollection"/>
  
  <path id="tempcollection.module.bootclasspath">
    <!-- Paths to be included in compilation bootclasspath -->
  </path>
  
  <path id="tempcollection.module.production.classpath">
    <path refid="${module.jdk.classpath.tempcollection}"/>
  </path>
  
  <path id="tempcollection.runtime.production.module.classpath">
    <pathelement location="${tempcollection.output.dir}"/>
  </path>
  
  <path id="tempcollection.module.classpath">
    <path refid="${module.jdk.classpath.tempcollection}"/>
    <pathelement location="${tempcollection.output.dir}"/>
  </path>
  
  <path id="tempcollection.runtime.module.classpath">
    <pathelement location="${tempcollection.testoutput.dir}"/>
    <pathelement location="${tempcollection.output.dir}"/>
  </path>
  
  
  <patternset id="excluded.from.module.tempcollection">
    <patternset refid="ignored.files"/>
  </patternset>
  
  <patternset id="excluded.from.compilation.tempcollection">
    <patternset refid="excluded.from.module.tempcollection"/>
  </patternset>
  
  
  <target name="compile.module.tempcollection" depends="compile.module.tempcollection.production,compile.module.tempcollection.tests" description="Compile module TempCollection"/>
  
  <target name="compile.module.tempcollection.production" depends="register.custom.compilers" description="Compile module TempCollection; production classes"/>
  
  <target name="compile.module.tempcollection.tests" depends="register.custom.compilers,compile.module.tempcollection.production" description="compile module TempCollection; test classes" unless="skip.tests"/>
  
  <target name="clean.module.tempcollection" description="cleanup module">
    <delete dir="${tempcollection.output.dir}"/>
    <delete dir="${tempcollection.testoutput.dir}"/>
  </target>
</project>