<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ih.api.dal.HeatexchangerunitMapper">

    <resultMap type="com.ih.api.model.Heatexchangerunit" id="heatexchangerunitMap">
        <id column="id" property="id"/>
        <result column="StationID" property="stationID"/>
        <result column="UnitNumber" property="unitNumber"/>
        <result column="CreateTime" property="createTime"/>
        <result column="CreaterID" property="createrID"/>
        <result column="CrewID" property="crewID"/>
        <result column="UpdateDesc" property="updateDesc"/>
    </resultMap>

    <sql id="Base_Column_List">
        `id`,`StationID`,`UnitNumber`,`CreateTime`,`CreaterID`,`Address`,`CrewID`,`UpdateDesc`
    </sql>

    <select id="getPaging" resultType="com.ih.api.model.Heatexchangerunit"
            resultMap="heatexchangerunitMap">
        SELECT
        heu.`id`,heu.`stationID`,heu.`UnitNumber`,heu.`CreateTime`,heu.`CreaterID`,heu.`Address`,heu.`CrewID`,heu.`UpdateDesc`,
        hes.`Name` AS stationName, hes.`CompanyID` AS companyID, com.`Name` AS companyName
        FROM HeatExchangerUnit heu LEFT JOIN HeatExchangeStation hes ON heu.`StationID` = hes.`id`
        LEFT JOIN company com ON hes.`CompanyID`=com.`id`
        <where>
            <if test="companyID!=-1">

                and (com.id = #{companyID} or  com.ParentID = #{companyID})
            </if>
            <if test="stationID!=-1">
                AND heu.`stationID`=#{stationID}
            </if>
            <if test="unitNumber!=''">
                AND heu.`UnitNumber` LIKE '%${unitNumber}%'
            </if>
            <if test="crewID!=''">
                AND heu.`CrewID` LIKE '%${crewID}%'
            </if>
        </where>
        order by ${orderBy} limit #{offset},#{pageSize}
    </select>

    <select id="get" resultType="com.ih.api.model.Heatexchangerunit" resultMap="heatexchangerunitMap">
        SELECT
        <include refid="Base_Column_List"/>
        FROM heatexchangerunit WHERE id=#{id}
    </select>

    <update id="update" parameterType="com.ih.api.model.Heatexchangerunit"
            flushCache="true"
            statementType="PREPARED"
            timeout="20">
        Update heatexchangerunit
        <set>
            <if test="model.stationID!=null">
                `StationID`=#{model.stationID},
            </if>
            <if test="model.unitNumber!=null">
                `UnitNumber`=#{model.unitNumber},
            </if>
            <if test="model.createTime!=null">
                `CreateTime`=#{model.createTime},
            </if>
            <if test="model.createrID!=null">
                `CreaterID`=#{model.createrID},
            </if>
            <if test="model.address!=null">
                `Address`=#{model.address},
            </if>
            <if test="model.crewID!='' and model.crewID!=null">
                `CrewID`=#{model.crewID},
            </if>
            <if test="model.updateDesc!=null">
                `UpdateDesc`=#{model.updateDesc}
            </if>
        </set>
        WHERE id=#{model.id}
    </update>

    <update id="delete" parameterType="java.lang.Integer" statementType="PREPARED"
            timeout="20">
        DELETE FROM heatexchangerunit WHERE id=#{id}
    </update>

    <insert id="insert" parameterType="com.ih.api.model.Heatexchangerunit"
            flushCache="true"
            statementType="PREPARED"
            keyProperty="id"
            keyColumn=""
            useGeneratedKeys="true"
            timeout="20">
        INSERT INTO heatexchangerunit(`StationID`,`UnitNumber`,`CreateTime`,`CreaterID`,`Address`,`CrewID`,`UpdateDesc`)
        VALUES(#{model.stationID},#{model.unitNumber},#{model.createTime},#{model.createrID},
        #{model.address},#{model.crewID},#{model.updateDesc})
    </insert>


    <select id="getCount" parameterType="java.lang.String" resultType="java.lang.Integer">
        SELECT count(*)
        FROM HeatExchangerUnit heu LEFT JOIN HeatExchangeStation hes ON heu.`StationID` = hes.`id`
        <where>
            <if test="companyID!=-1">
                AND hes.`CompanyID`=#{companyID}
            </if>
            <if test="stationID!=-1">
                AND heu.`StationID`=#{stationID}
            </if>
            <if test="unitNumber!=''">
                AND heu.`UnitNumber` LIKE '%${unitNumber}%'
            </if>
            <if test="crewID!=''">
                AND heu.`CrewID` LIKE '%${crewID}%'
            </if>
        </where>
    </select>

    <select id="getByName" resultType="com.ih.api.model.Heatexchangerunit">
        SELECT
        <include refid="Base_Column_List"/>
        FROM heatexchangerunit WHERE `StationID` = #{stationID} AND `UnitNumber` = #{unitNumber}
    </select>
</mapper>

